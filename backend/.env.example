# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/edufocus?retryWrites=true&w=majority

# JWT Secret (use a strong random string in production)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=30d

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Server Port (Render will set this automatically)
PORT=5002

# CORS - Frontend URL(s), comma-separated for multiple origins
# Example: https://edufocus.vercel.app,https://www.edufocus.app
FRONTEND_URL=http://localhost:4200

# Node Environment
NODE_ENV=production

# Mail / Notifications (Gmail App Password)
MAIL_PROVIDER=gmail
MAIL_USER=your_email@gmail.com
MAIL_APP_PASSWORD=your_gmail_app_password
MAIL_FROM_NAME=EduFocus
MAIL_FROM_EMAIL=your_email@gmail.com

# Google AI / Gemini (optional - for AI study advisor)
GOOGLE_API_KEY=your_google_api_key
